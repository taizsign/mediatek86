{% extends "base.html.twig" %}
{% block body %}
    <div class="row justify-content-center mt-5">
        <div class="col-md-4">
            <h4 class="text-info mb-3">Connexion</h4>
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans({}, 'security') }}</div>
            {% endif %}
            <form method="POST" action="{{ path('login') }}">
                <div class="mb-3">
                    <label for="username" class="form-label">Identifiant</label>
                    <input type="text" class="form-control" id="username" name="_username"
                           value="{{ last_username }}" required autofocus>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Mot de passe</label>
                    <input type="password" class="form-control" id="password" name="_password" required>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn btn-info">Se connecter</button>
            </form>
        </div>
    </div>
{% endblock %}
